# ─── Appwrite (Client) ────────────────────────────────────────────────────────
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here
VITE_APPWRITE_DATABASE_ID=nexusapi-db
VITE_APPWRITE_PROJECTS_COLLECTION_ID=projects
VITE_APPWRITE_REQUESTS_COLLECTION_ID=requests
VITE_APPWRITE_DOCS_COLLECTION_ID=docs
VITE_APPWRITE_MEMBERS_COLLECTION_ID=project_members
VITE_APPWRITE_FEEDBACK_COLLECTION_ID=feedback
VITE_APPWRITE_SETTINGS_COLLECTION_ID=settings
VITE_APPWRITE_FEEDBACK_BUCKET_ID=feedback-screenshots
VITE_APPWRITE_MANAGE_USERS_FUNCTION_ID=nexus-manage-users
