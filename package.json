{
  "name": "api-docs",
  "private": true,
  "version": "1.0.2",
  "description": "Nexus — API Testing & Documentation Platform",
  "author": "Eduzere <hello@eduzere.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "setup": "node scripts/setup-appwrite.mjs",
    "setup:settings": "node scripts/setup-settings.mjs",
    "generate-icons": "python3 electron/generate-icons.py",
    "electron:dev": "concurrently -k -n \"VITE,ELECTRON\" -c \"blue,green\" \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=true vite build && electron-builder",
    "electron:build:win": "cross-env ELECTRON_BUILD=true vite build && electron-builder --win",
    "electron:build:mac": "cross-env ELECTRON_BUILD=true vite build && electron-builder --mac",
    "electron:build:linux": "cross-env ELECTRON_BUILD=true vite build && electron-builder --linux"
  },
  "build": {
    "appId": "com.eduzere.nexus",
    "productName": "Nexus",
    "copyright": "Copyright © 2026 Eduzere",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/flash.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/icons/flash.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/flash.png",
      "category": "Development"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jissantoindia",
        "repo": "nexus"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "appwrite": "^25.0.0",
    "axios": "^1.16.0",
    "form-data": "^4.0.5",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^7.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "node-appwrite": "^24.0.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.5",
    "workbox-window": "^7.4.1"
  }
}
